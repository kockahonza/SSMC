Cell[BoxData[
 RowBox[{"l", "\[Rule]", 
  FractionBox[
   SuperscriptBox["\[ExponentialE]", "x"], 
   RowBox[{"1", "+", 
    SuperscriptBox["\[ExponentialE]", "x"]}]]}]], "Output",
 CellChangeTimes->{3.9809411246512127`*^9, 3.980941270674728*^9},
 CellLabel->"Out[64]=",ExpressionUUID->"6955e568-d32b-40c9-972d-00535086b467"]
