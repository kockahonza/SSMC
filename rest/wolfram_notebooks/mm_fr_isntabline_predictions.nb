}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"s1", "=", 
  RowBox[{"l", "->", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"Exp", "[", "x", "]"}], "/", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"Exp", "[", "x", "]"}]}], ")"}]}], ")"}]}]}]], "Input",
