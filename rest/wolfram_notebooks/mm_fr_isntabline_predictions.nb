 CellLabel->"In[63]:=",ExpressionUUID->"e6eba862-0211-4d2d-ab00-ccae0f1e6bf2"],

Cell[BoxData[
 FractionBox["l", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"1", "-", "l"}], ")"}], " ", "p", " ", 
   RowBox[{"(", 
    RowBox[{"1", "-", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", "l"}], ")"}], " ", "p"}]}], ")"}]}]]], "Output",
